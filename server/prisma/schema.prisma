generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Neighborhood {
  id            Int            @id @default(autoincrement())
  name          String
  announcements Announcement[]
  events        Event[]
  forums        Forum[]
  listings      Listing[]
  posts         Post[]
  users         User[]
}

model User {
  id             Int            @id @default(autoincrement())
  firstName      String
  lastName       String
  email          String         @unique
  password       String
  photo          String?
  role           Role           @default(USER)
  neighborhoodId Int
  createdAt      DateTime       @default(now())
  announcements  Announcement[]
  comments       Comment[]
  hostedEvents   Event[]        @relation("EventHost")
  listings       Listing[]
  notifications  Notification[]
  posts          Post[]
  neighborhood   Neighborhood   @relation(fields: [neighborhoodId], references: [id])
  attending      Event[]        @relation("EventAttendees")
}

model Event {
  id             Int          @id @default(autoincrement())
  name           String
  description    String
  place          String
  date           DateTime
  neighborhoodId Int
  createdAt      DateTime     @default(now())
  duration       String?
  price          Decimal?     @db.Decimal(10, 2)
  authorId       Int?
  author         User?        @relation("EventHost", fields: [authorId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  neighborhood   Neighborhood @relation(fields: [neighborhoodId], references: [id])
  attendees      User[]       @relation("EventAttendees")
}

model Forum {
  id             Int          @id @default(autoincrement())
  name           String
  description    String
  icon           String?
  neighborhoodId Int
  createdAt      DateTime     @default(now())
  neighborhood   Neighborhood @relation(fields: [neighborhoodId], references: [id])
  posts          Post[]
}

model Post {
  id             Int          @id @default(autoincrement())
  title          String
  content        String
  media          String?
  authorId       Int
  neighborhoodId Int
  forumId        Int?
  createdAt      DateTime     @default(now())
  comments       Comment[]
  author         User         @relation(fields: [authorId], references: [id])
  forum          Forum?       @relation(fields: [forumId], references: [id])
  neighborhood   Neighborhood @relation(fields: [neighborhoodId], references: [id])
}

model Comment {
  id        Int      @id @default(autoincrement())
  content   String
  authorId  Int
  postId    Int
  createdAt DateTime @default(now())
  author    User     @relation(fields: [authorId], references: [id])
  post      Post     @relation(fields: [postId], references: [id])
}

model Announcement {
  id             Int          @id @default(autoincrement())
  title          String
  content        String
  media          String?
  authorId       Int
  neighborhoodId Int
  createdAt      DateTime     @default(now())
  author         User         @relation(fields: [authorId], references: [id])
  neighborhood   Neighborhood @relation(fields: [neighborhoodId], references: [id])
}

model Listing {
  id             Int           @id @default(autoincrement())
  title          String
  description    String
  price          Decimal?      @db.Decimal(10, 2)
  contact        String
  status         ListingStatus @default(AVAILABLE)
  authorId       Int
  neighborhoodId Int
  createdAt      DateTime      @default(now())
  author         User          @relation(fields: [authorId], references: [id])
  neighborhood   Neighborhood  @relation(fields: [neighborhoodId], references: [id])
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int
  type      String   @default("system")
  title     String
  body      String
  link      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum Role {
  USER
  COUNCILLOR
  ADMIN
}

enum ListingStatus {
  AVAILABLE
  RESERVED
  SOLD
}
